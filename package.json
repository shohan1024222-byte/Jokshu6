{
  "name": "jokshu-voting-new",
  "version": "1.0.0",
  "description": "JOKSHU Voting System - Jagannath University Student Union Election (Optimized for Expo.dev)",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "node ./scripts/expo-start-safe.js",
    "start:lan": "node ./scripts/expo-start-safe.js --lan",
    "start:lan:clear": "node ./scripts/expo-start-safe.js --lan --clear",
    "start:tunnel": "node ./scripts/expo-start-safe.js --tunnel",
    "start:clear": "node ./scripts/expo-start-safe.js --clear",
    "start:tunnel:clear": "node ./scripts/expo-start-safe.js --tunnel --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.2",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.2",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.9.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": []
    }
  },
  "private": true
}
